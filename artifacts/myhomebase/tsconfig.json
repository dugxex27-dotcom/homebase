{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/schema": ["../../lib/db/src/schema/schema.ts"],
      "@shared/distance-utils": ["../../artifacts/api-server/src/shared/distance-utils.ts"],
      "@shared/cost-baselines": ["../../.migration-backup/shared/cost-baselines.ts"],
      "@shared/cost-helpers": ["../../.migration-backup/shared/cost-helpers.ts"],
      "@shared/location-maintenance-data": ["../../.migration-backup/shared/location-maintenance-data.ts"]
    }
  },
  "references": [
    {
      "path": "../../lib/api-client-react"
    }
  ]
}
