modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "myhomebase-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "checkout-test-only"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "myhomebase-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "libs-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "quiz-typecheck"

[[workflows.workflow]]
name = "myhomebase-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/myhomebase run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "checkout-test-only"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/myhomebase exec vitest run --config vitest.config.ts src/pages/contractor-checkout.test.tsx --reporter=verbose"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-server-typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[[workflows.workflow]]
name = "myhomebase-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/myhomebase run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "libs-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck:libs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "quiz-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/quiz run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 18359
externalPort = 3002

[[ports]]
localPort = 19492
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

