# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# No need to store the pnpm store twice.
.local

# All artifacts are pre-built (api-server → dist/index.mjs, myhomebase/quiz → dist/public/).
# node_modules are not needed at runtime — excluding them shrinks the image and
# prevents stale transitive packages from being flagged by the security scanner.
node_modules
